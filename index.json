{
  "name": "Sony PlayStation Portable",
  "shortName": "psp",
  "description": "PSP games via custom import",
  "acceptedFilenameRegex": "^(.*)\\.(iso|cso|pbp)$",
  "amStartArguments": "-n org.ppsspp.ppsspp/.PpssppActivity -a android.intent.action.VIEW -d {file.uri} --activity-clear-task --activity-clear-top --activity-no-history",
  "uniqueId": "psp"
}
